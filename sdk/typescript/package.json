{
  "name": "@vaea/flash",
  "version": "0.1.0",
  "description": "VAEA Flash — Universal Flash Loan SDK for Solana. Flash loan any SPL token in one line.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "echo \"Tests require running API\" && exit 0",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/web3.js": "^1.91.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0"
  },
  "keywords": ["solana", "flash-loan", "defi", "vaea", "spl-token", "lending"],
  "author": "VAEA Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaea-protocol/flash"
  },
  "homepage": "https://vaea.fi/flash",
  "type": "commonjs"
}
